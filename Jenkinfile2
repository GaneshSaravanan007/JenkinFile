pipeline {
    agent any

    stages {

        stage("Checkout Repos") {
            steps {

                dir(params.DockerFileDir) {
                    git branch: 'master',
                        credentialsId: 'gitPass',
                        url: 'https://github.com/GaneshSaravanan007/Docker-Project.git'
                }

                dir(params.KubernetesFileDirectory) {
                    git branch: 'master',
                        credentialsId: 'gitPass',
                        url: 'https://github.com/GaneshSaravanan007/KubernetsYaml.git'
                }

                sh 'ls -lrt'
            }
        }

        stage("building image") {
            steps {
                sh '''
                cd "$WORKSPACE/$DockerFileDir"
                docker build -t "$imageName" .
                docker images
                '''
            }
        }

        stage("pushing image to docker hub") {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'DockerHub',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {
                    sh '''
                    cd "$WORKSPACE/$DockerFileDir"
                    echo "$PASS" | docker login -u "$USER" --password-stdin
                    docker tag "$imageName" "$USER/$repoName:$imageName"
                    docker push "$USER/$repoName:$imageName"
                    '''
                }
            }
        }

        stage("K8s Dry Run Validation") {
            steps {
                sh '''
                cd "$WORKSPACE/$KubernetesFileDirectory"
                echo "$rootPass" | sudo -S kubectl apply -f "$yamlFile" --dry-run=server
                '''
            }
        }

        stage("Deploy to Kubernetes") {
            steps {
                sh '''
                cd "$WORKSPACE/$KubernetesFileDirectory"
                echo "$rootPass" | sudo -S kubectl apply -f "$yamlFile"
                echo "$rootPass" | sudo -S kubectl get all
                '''
            }
        }
    }
}
