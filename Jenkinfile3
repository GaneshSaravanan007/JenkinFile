pipeline {
    agent any

    stages {  

        stage("Checkout") {
            steps {
                git url: "https://github.com/GaneshSaravanan007/AWSTerraform.git",
                    credentialsId: "gitPass",
                    branch: "${params.branch}"
            }
        }

        stage("Terraform Ops") {
            steps {
                sh '''
                    terraform init
                    terraform plan
                '''

                input "Want to apply?"

                sh "terraform apply -auto-approve"
            }
        }

    }
}
