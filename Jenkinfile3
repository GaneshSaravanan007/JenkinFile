pipeline {
    agent any

    stages {  

        stage("Checkout") {
            steps {
                git url: "https://github.com/GaneshSaravanan007/AWSTerraform.git",
                    credentialsId: "gitPass",
                    branch: "${params.branch}"
            }
        }

        stage("Terraform Ops") {
            steps {
                dir(env.WORKSPACE){ 
                   sh ''' terraform init && \
                        terraform plan ''' 
                   input "want to apply" 
                   sh 'terraform apply -auto-approve' 
                }
            }
        }

    }
}
